{
  "manifest_version": 3,
  "name": "YTMusic Lyrics Translator",
  "version": "1.0.0",
  "description": "Real-time lyrics and translation overlay for YouTube Music. Fetches synced lyrics from multiple sources (LRCLib, Genius, Letras.com) and translates via Google Translate.",
  "permissions": ["storage", "scripting", "tabs", "windows"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://translate.googleapis.com/translate_a/*",
    "https://lrclib.net/api/*",
    "https://genius.com/*",
    "https://www.letras.com/*/*/"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YTMusic Lyrics",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
